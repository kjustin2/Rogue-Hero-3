{
  "name": "rogue-hero-3",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "electron": "electron .",
    "standalone": "npm run build && electron .",
    "verify": "tsc --noEmit && vite build",
    "smoke": "electron scripts/smoke-electron.cjs",
    "smoke:boss-pause": "node scripts/smoke-boss-pause.mjs",
    "smoke:menu-perf": "node scripts/smoke-menu-perf.mjs",
    "smoke:perf": "node scripts/smoke-perf.mjs",
    "smoke:perf:stress": "node scripts/smoke-perf-stress.mjs",
    "smoke:polish": "node scripts/smoke-polish.mjs",
    "smoke:cards": "node scripts/smoke-card-visuals.mjs",
    "smoke:display": "node scripts/smoke-display.mjs",
    "smoke:display-electron": "electron scripts/smoke-display-electron.cjs",
    "smoke:save-persist": "node scripts/smoke-save-persist.mjs",
    "smoke:loop-resilience": "node scripts/smoke-loop-resilience.mjs",
    "smoke:perf-instrument": "node scripts/smoke-perf-instrument.mjs",
    "perf:soak": "npm run build && electron scripts/perf-soak-electron.cjs",
    "perf:bench": "node scripts/perf-bench.mjs",
    "perf:baseline": "node scripts/perf-bench.mjs --save-baseline",
    "perf:lag-hunt": "node scripts/loop/lag-hunt.mjs",
    "visual:diff": "node scripts/visual-diff.mjs",
    "ai:look": "node scripts/ai-look.mjs",
    "loop": "node scripts/loop/orchestrate.mjs",
    "loop:dry": "node scripts/loop/orchestrate.mjs --no-implement --max-cycles 1",
    "loop:capture": "node scripts/loop/capture.mjs",
    "loop:logic": "node scripts/loop/logic-tests.mjs",
    "loop:observe": "node scripts/loop/observe.mjs",
    "test:play": "npm run build && electron scripts/smoke-electron.cjs",
    "package": "npm run build && electron-builder --win portable",
    "dist": "npm run build && electron-builder --win nsis",
    "dist:dir": "npm run build && electron-builder --win --dir"
  },
  "author": "Justin Kramer",
  "build": {
    "appId": "com.roguehero.emberrift",
    "productName": "Rogue Hero 3",
    "files": ["electron-main.cjs", "electron-ipc.cjs", "preload.cjs", "dist/**/*", "package.json"],
    "directories": { "output": "release" },
    "win": { "target": ["nsis"] },
    "portable": { "artifactName": "Rogue-Hero-3-${version}-portable.exe" },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Rogue Hero 3"
    }
  },
  "dependencies": {
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "postprocessing": "^6.36.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.60.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
